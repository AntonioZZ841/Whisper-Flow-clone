# Copy to `.env` and fill in what you have. Everything is optional: with no
# keys at all the app runs in demo mode (mock ASR + passthrough Flow).

PORT=3000
#HOST=0.0.0.0  # default: every interface, so other devices on your LAN can reach it. Use 127.0.0.1 for localhost-only.
#MAX_UPLOAD_MB=200  # uploaded-recording size cap; uploads spool to a temp file, not RAM

# ── Stage 1 · ASR (speech → raw transcript) ────────────────────────────────
# Provider selection (default: auto). auto = cloud key if set, else local
# NeMo when an NVIDIA GPU is present, else mock.
#TRANSCRIPTION_PROVIDER=auto   # auto | mock | openai-compatible | nemo

# openai-compatible: any /audio/transcriptions endpoint — api.openai.com by
# default, or a self-hosted whisper.cpp / faster-whisper server. Leave the key
# empty (and no GPU) to run in mock mode (a canned disfluent utterance).
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
TRANSCRIPTION_MODEL=whisper-1

# nemo: local NVIDIA NeMo ASR — only offered when the server has an NVIDIA GPU
# (detected via nvidia-smi). Requires `pip install "nemo_toolkit[asr]"` and
# ffmpeg. See scripts/nemo_transcribe.py.
#NEMO_MODEL=nvidia/parakeet-tdt-0.6b-v2
#NEMO_PYTHON=python3           # interpreter used to run the NeMo sidecar
#NEMO_ENABLED=true             # set false to keep auto from picking NeMo on a GPU box
#NEMO_DIAR_MODEL=nvidia/diar_sortformer_4spk-v1  # speaker-diarization model for meeting mode
#NEMO_KEEP_WARM=true           # resident worker keeps models on the GPU; false = one-shot sidecar per request

# ── Stage 2 · Flow (raw transcript → clean text) ───────────────────────────
# The LLM that performs Smart Formatting + Backtrack. The provider is
# auto-detected from which key is set; override explicitly with
# FLOW_PROVIDER=anthropic | openai-compatible | passthrough.

# Option A — Claude (default model: claude-sonnet-5)
ANTHROPIC_API_KEY=
#FLOW_MODEL=claude-sonnet-5

# Option B — any OpenAI-compatible chat API (example: DeepSeek)
#FLOW_PROVIDER=openai-compatible
#FLOW_API_KEY=sk-...
#FLOW_API_URL=https://api.deepseek.com/chat/completions
#FLOW_MODEL=deepseek-chat
